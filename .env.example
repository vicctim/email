# ==========================================
# Email Content Extractor — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ==========================================

# ── App ──────────────────────────────────
APP_SECRET_KEY=gere-uma-chave-segura-aqui
APP_ENV=production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha
ACCESS_TOKEN_EXPIRE_MINUTES=480
IMAP_LISTENER_ENABLED=true
SETTINGS_STORAGE_PATH=media/settings.json

# ── PostgreSQL ───────────────────────────
POSTGRES_USER=emailext
POSTGRES_PASSWORD=TROQUE-ESTA-SENHA
POSTGRES_DB=emailext

# ── Gmail IMAP ───────────────────────────
# Habilite 2FA no Gmail e gere uma App Password:
# https://myaccount.google.com/apppasswords
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Evolution API (WhatsApp) ─────────────
EVOLUTION_API_URL=https://evolutionapi.victorsamuel.com.br
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=emailext
WHATSAPP_NOTIFY_NUMBER=5534999999999

# ── Delay de Publicação (minutos) ────────
DEFAULT_PUBLISH_DELAY=10

# ── Frontend ─────────────────────────────
NEXT_PUBLIC_API_URL=https://emailext-api.victorsamuel.com.br

# ── Desenvolvimento Local (opcional) ─────
POSTGRES_LOCAL_PORT=5433
REDIS_LOCAL_PORT=6380
BACKEND_LOCAL_PORT=8000
FRONTEND_LOCAL_PORT=3000
